{
  "name": "@tofrankie/miniprogram-ga4",
  "type": "module",
  "version": "0.0.2",
  "packageManager": "pnpm@10.32.0",
  "description": "适用于小程序的 Google Analytics 4",
  "license": "MIT",
  "keywords": [
    "google analytics",
    "google analytics 4",
    "ga4",
    "ga",
    "miniprogram",
    "wechat miniprogram",
    "微信小程序",
    "支付宝小程序",
    "抖音小程序"
  ],
  "exports": {
    "types": {
      "import": "./dist/index.d.mts",
      "require": "./dist/index.d.cts"
    },
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build:tsdown": "tsdown",
    "build": "run-s build:tsdown copy:cjs-to-js",
    "prepublishOnly": "pnpm build",
    "copy:cjs-to-js": "node --input-type=module -e \"import { copyFileSync } from 'node:fs'; copyFileSync('dist/index.cjs', 'dist/index.js')\"",
    "lint": "run-s lint:eslint lint:prettier tsc tsc:test lint:publint",
    "lint:eslint": "eslint . --cache --fix",
    "lint:prettier": "prettier . --cache --write --log-level silent",
    "lint:publint": "publint",
    "tsc": "tsc -b",
    "tsc:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "docs:api": "typedoc",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tofrankie/eslint": "^0.0.10",
    "@tofrankie/prettier": "^0.0.5",
    "@types/node": "^25.4.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "miniprogram-api-typings": "^5.1.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "tsdown": "^0.21.1",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
